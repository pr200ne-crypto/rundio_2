# Clerk — https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google ログイン: Dashboard → User & Authentication → Social connections → Google を有効化

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/home
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/home

# Supabase — https://supabase.com/dashboard → Settings → API
# Project URL と「同じプロジェクト」のキーを使う（別プロジェクトを混ぜない）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# クライアント用: Dashboard の anon public（JWT 全文。途中で切らない）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ サーバー専用。anon ではなく service_role のシークレット全文（前後に引用符やスペースを付けない）
SUPABASE_SERVICE_ROLE_KEY=
